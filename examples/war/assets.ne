        "23222322",
        "22222222",
        // ── 24: small spade ♠ ────────────────────────────
        // 6×6 black pip centred on a fully-opaque white 8×8 tile.
        // Used as the top-right corner indicator on spade cards.
        //     ...##...
        //     ..####..
        //     .######.
        //     ..####..
