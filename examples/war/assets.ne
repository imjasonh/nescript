        "222..3.2",
        "22.3.3.2",
        "22.333.2",
        "22222222",
        // ── 22: rank Q ───────────────────────────────────
        "22222222",
        "2.3333.2",
        "2.3..3.2",
        "2.3..3.2",
        "2.3.33.2",
        "2.3333.2",
        "22.33.32",
        "22222222",
        // ── 23: rank K ───────────────────────────────────
