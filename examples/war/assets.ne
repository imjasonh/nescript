        "2.3333.2",
        "2.3..3.2",
        "2.3333.2",
        "2.3..3.2",
        "2.3..3.2",
        "2.3333.2",
        "22222222",
        // ── 19: rank 9 ───────────────────────────────────
        "22222222",
