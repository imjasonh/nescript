        //     ................
        //     .....######.....
        //     ....########....
        //     ....########....
        //     .....######.....
        //     ..###..######...
        //     .#####.########.
        //     .###############
        //     ################
        //     .##############.
        //     ..############..
        //     .......##.......
        //     .....######.....
        //     ....########....
        //     ................
        //     ................
        "22222222",
        "22222333",
        "22223333",
        "22223333",
        "22222333",
        "22333222",
        "23333322",
        "23333333",
        // ── 32: big spade — TR quadrant ──────────────────
        "22222222",
        "32222222",
        "33222222",
        "33322222",
        "33332222",
        "33333222",
        "33333322",
        "33333332",
        // ── 33: big heart — TR quadrant ──────────────────
        "22222222",
        "22111122",
        "11111112",
        "11111111",
        "11111111",
        "11111111",
        "11111111",
        "11111111",
        // ── 34: big diamond — TR quadrant ────────────────
        "22222222",
        "12222222",
        "11222222",
        "11122222",
        "11112222",
        "11111222",
        "11111122",
        "11111112",
        // ── 35: big club — TR quadrant ───────────────────
