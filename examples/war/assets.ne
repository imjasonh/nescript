        //     .##############.
        //     ..############..
        //     ...##########...
        //     ....########....
        //     .....######.....
        //     .......##.......
        //     ................
        "22222222",
        "22111122",
        "21111111",
        "11111111",
        "11111111",
        "11111111",
        "11111111",
        "11111111",
        // ── 30: big diamond — TL quadrant ────────────────
        // Full 16×16 diamond shape (symmetric rhombus):
