        "2.3333.2",
        "22...3.2",
        "2.3333.2",
        "22222222",
        // ── 20: rank 10 (condensed "1" + "0") ─────────────
        // "10" squeezed into an 8x8 tile. The "1" takes columns
        // 0-1, a gap, the "0" takes columns 4-7.
        "22222222",
        "2.3.33.2",
        "233.3..3",
        "2.3.3..3",
        "2.3.3..3",
        "2.3.3..3",
        "2.3.33.2",
        "22222222",
