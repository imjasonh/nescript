        "22222222",
        "22233222",
        "22333322",
        "23333332",
        "22333322",
        "22233222",
        "22233222",
        "22222222",
        // ── 25: small heart ♥ ────────────────────────────
        // Red pip on white (palette index 1 = red).
        //     .##..##.
        //     ########
        //     ########
        //     ########
        //     .######.
        //     ..####..
        //     ...##...
        "22222222",
        "21122112",
        "21111112",
        "21111112",
        "22111122",
        "22211222",
        "22221222",
        "22222222",
        // ── 26: small diamond ♦ ──────────────────────────
