// jumpjet/assets.ne — the Tileset sprite block.
//
// Every custom 8×8 CHR tile is stacked vertically inside one
// `sprite Tileset { pixels: [...] }`. Tile 0 is the linker-reserved
// builtin smiley; every custom tile starts at index 1 and the
// constants in constants.ne pin each name to its index.
//
// Colour vocabulary (sp0 / bg0..bg2 are kept in lockstep so the
// same tile renders right under either layer):
//     . / 0   transparent / sub-palette index 0
//     1       white       (jet hi-lights, alphabet, digits, missile, hearts via bg2)
//     2       red         (enemy planes, heart, explosion)
//     3       lt_gray     (jet body, tank, bomb, ground hatching)

sprite Tileset {
    pixels: [
        // ── 1: TILE_SKY ─ all-transparent fill for the sky band
        "........",
        "........",
        "........",
        "........",
        "........",
        "........",
        "........",
        "........",
        // ── 2: TILE_GROUND ─ solid dirt with subtle hatching
        "33333333",
        "33133333",
        "33333333",
        "33333133",
        "33333333",
        "31333333",
        "33333333",
        "33333313",
        // ── 3: TILE_HORIZON ─ grass top over dirt bottom
        "11331133",
        "33333333",
        "33333333",
        "33333333",
        "33333333",
        "33133333",
        "33333133",
        "33333333",

        // ── 4..29: alphabet A..Z (5 wide × 7 tall, top-left aligned) ─

        // 4: A
        "........",
        ".111....",
        "1...1...",
        "1...1...",
        "11111...",
        "1...1...",
        "1...1...",
        "........",
        // 5: B
        "........",
