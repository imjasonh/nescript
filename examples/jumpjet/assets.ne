        // on a light-gray fuselage.

        // 40: jet R, top-left (tail half)
        "........",
        "........",
        "........",
        "...3....",
        "..33....",
        ".333....",
        "33333333",
        ".3333333",
        // 41: jet R, top-right (nose half)
        "........",
